{% extends "base.j2" %}

{% block content %}
    <h2>Hello {{ name or "there" }},</h2>

    <p>
      Thank you for creating an account with InfoGate. To complete your
      registration, please confirm your email address by clicking the button
      below.
    </p>

    <p>
      <a href="{{ verification_link }}"
         style="display:inline-block;padding:12px 20px;background:#2563eb;color:#ffffff;text-decoration:none;border-radius:6px;">
         Verify Your Email
      </a>
    </p>

    <p>
      If the button above does not work, copy and paste the link below into your browser:
    </p>

    <p>{{ verification_link }}</p>

    <p>
      If you did not create this account, you can safely ignore this email.
    </p>

    <p>
      Best regards,<br />
      The InfoGate Team
    </p>
{% endblock %}